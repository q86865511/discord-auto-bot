# ── runtime 持久化資料(SQLite + 加密金鑰 + Discord session)──
# 全集中在 data/ 一個資料夾,直接整個排除
data/

# ── runtime 日誌 ─────────────────────────────────────────────
# bot.log + 輪替 + slot_debug.log 都在 logs/
logs/

# ── 個人設定(可能含敏感資料)── 不會 commit
config.json
storage_state.json

# ── 舊版根目錄位置(向下相容,bootstrap 會自動搬到 data/ 或 logs/)──
bot.db
bot.db-journal
bot.db-wal
bot.db-shm
secret.key
secret.key.bak
slot_analysis.json
gambling_history.json
bot.log
bot.log.1
bot.log.2
bot.log.3
slot_debug.log

# ── 匯出的賭博紀錄 ──
exports/

# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.venv/
venv/
env/

# IDE / 編輯器
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# Claude Code 本地設定 + 接手筆記(CLAUDE.md 是 AI session 用,不入 repo)
.claude/
CLAUDE.md

# Playwright 暫存
playwright-report/
test-results/

# 開發過程任意產生的 log 檔(運行時的 bot.log 已被 logs/ 涵蓋)
*.log
